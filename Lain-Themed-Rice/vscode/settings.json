{
    "editor.fontFamily": "Cascadia Code",
    "terminal.integrated.fontFamily": "Cascadia Code PL",
    "workbench.colorTheme": "b93ab4ea-ff96-4459-8fa2-0caae5bc7116",
    "doki.sticker.path": "/home/aelis/Pictures/Icons/lain-bear-sticker.png",
    "editor.fontLigatures": "'calt', 'ss01'",
    "extensions.allowed": "*",
    "security.workspace.trust.untrustedFiles": "open",

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "keyword",
                    "storage",
                    "entity.name",
                    "entity.name.type",
                    "entity.name.function",
                    "variable",
                    "variable.language",
                    "variable.parameter",
                    "string",
                    "constant",
                    "markup",
                    "meta.function-call",
                    "support.function"
                ],
                "settings": {
                    "fontStyle": "italic"
                }
            }
        ]
    }
}
